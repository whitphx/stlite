{
  "name": "@stlite/react",
  "version": "1.6.1",
  "description": "Stlite React library",
  "keywords": [
    "pyodide",
    "stlite",
    "streamlit",
    "wasm",
    "webassembly"
  ],
  "bugs": {
    "url": "https://github.com/whitphx/stlite/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Yuichiro Tachibana (Tsuchiya)",
    "url": "https://www.whitphx.info/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whitphx/stlite.git",
    "directory": "packages/react"
  },
  "files": [
    "build/**/*",
    "vite-plugin/dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "self-development": "./src/index.ts",
      "import": {
        "types": "./build/stlite.d.ts",
        "default": "./build/stlite.js"
      }
    },
    "./vite-utils": {
      "self-development": "./src/vite-utils/index.ts",
      "import": {
        "types": "./build/vite-utils.d.ts",
        "default": "./build/vite-utils.js"
      }
    },
    "./stlite.css": "./build/stlite.css",
    "./vite-plugin": {
      "import": {
        "types": "./vite-plugin/dist/index.d.ts",
        "default": "./vite-plugin/dist/index.mjs"
      }
    }
  },
  "scripts": {
    "start": "vite",
    "build": "run-p 'build:*'",
    "build:lib": "tsc --noEmit && vite build",
    "build:vite-plugin": "cd vite-plugin && tsdown",
    "test": "vitest",
    "test:e2e": "yarn --cwd e2e-tests test",
    "test:e2e:headed": "yarn --cwd e2e-tests test:headed",
    "test:e2e:ui": "yarn --cwd e2e-tests test:ui",
    "test:e2e:update-snapshots": "yarn --cwd e2e-tests test:update-snapshots",
    "fix:lint": "oxlint --fix src",
    "fix:format": "oxfmt .",
    "check:lint": "oxlint src",
    "check:format": "oxfmt --check ."
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@laynezh/vite-plugin-lib-assets": "^2.1.3",
    "@stlite/common": "workspace:^",
    "@stlite/kernel": "workspace:^",
    "@stlite/tooling": "workspace:^",
    "@streamlit/app": "workspace:^",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "codedent": "^0.1.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-toastify": "^11.0.2",
    "sass": "^1.90.0",
    "tsdown": "^0.16.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-wasm": "^3.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
