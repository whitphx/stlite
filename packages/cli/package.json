{
  "name": "@stlite/cli",
  "version": "0.0.0",
  "bugs": {
    "url": "https://github.com/whitphx/stlite/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/whitphx/stlite.git",
    "directory": "packages/cli"
  },
  "bin": {
    "stlite": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/cli.js --banner:js='#!/usr/bin/env node\nimport { createRequire as __cliCreateRequire } from \"node:module\"; const require = __cliCreateRequire(import.meta.url);' --external:pyodide --external:fs-extra --external:@stlite/app-packager --external:@stlite/browser --external:@stlite/desktop",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "fix:lint": "oxlint --fix src",
    "fix:format": "oxfmt .",
    "check:lint": "oxlint src",
    "check:format": "oxfmt --check ."
  },
  "dependencies": {
    "@stlite/app-packager": "workspace:^",
    "@stlite/browser": "workspace:^",
    "@stlite/common": "workspace:^",
    "@stlite/desktop": "workspace:^",
    "@stlite/sharing-common": "workspace:^",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/yargs": "^17.0.32",
    "esbuild": "^0.27.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
