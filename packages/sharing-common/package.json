{
  "name": "@stlite/sharing-common",
  "version": "0.90.3",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "start": "run-p start:proto start:ts",
    "build": "run-s build:proto build:ts",
    "start:ts": "tsc -b -w",
    "build:ts": "tsc -b",
    "pretest": "yarn build:proto",
    "test": "vitest",
    "build:proto": "protoc --ts_proto_out=. ./src/proto/*.proto --ts_proto_opt=esModuleInterop=true --ts_proto_opt=oneof=unions",
    "start:proto": "chokidar \"**/*.proto\" -c \"yarn run build:proto\"",
    "fix:lint": "oxlint --fix src",
    "fix:format": "oxfmt .",
    "check:lint": "oxlint src",
    "check:format": "oxfmt --check ."
  },
  "dependencies": {
    "protobufjs": "^7.2.4"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "ts-proto": "^2.11.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
